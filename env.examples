# ─── Step 1: Get API credentials from https://my.telegram.org/apps ───
API_ID=12345678
API_HASH=your_api_hash_here

# ─── Step 2: Get bot token from @BotFather on Telegram ───
BOT_TOKEN=123456789:ABCDefgh_your_bot_token_here

# ─── Step 3: Your own Telegram user ID (get it from @userinfobot) ───
OWNER_ID=987654321
